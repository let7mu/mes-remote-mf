{
  "name": ".",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve host-shell",
    "build": "ng build",
    "watch": "ng build --watch --configuration development",
    "test": "ng test",
    "start:host": "ng serve host-shell",
    "start:remote-azure": "ng serve remote-azure",
    "start:local-micro": "ng serve local-micro",
    "start:all": "concurrently -k -n host,remote-azure,local-micro -c blue,green,magenta \"npm run start:host\" \"npm run start:remote-azure\" \"npm run start:local-micro\"",
    "free-ports": "for p in 4200 4201 4202; do pid=$(lsof -ti tcp:$p); if [ -n \"$pid\" ]; then kill -9 $pid; fi; done",
    "start:all:clean": "npm run free-ports && npm run start:all",
    "build:host": "ng build host-shell",
    "build:remote-azure": "ng build remote-azure",
    "build:local-micro": "ng build local-micro"
  },
  "private": true,
  "dependencies": {
    "@angular-architects/native-federation": "17.1.8",
    "@angular/animations": "^17.3.0",
    "@angular/common": "^17.3.0",
    "@angular/compiler": "^17.3.0",
    "@angular/core": "^17.3.0",
    "@angular/forms": "^17.3.0",
    "@angular/platform-browser": "^17.3.0",
    "@angular/platform-browser-dynamic": "^17.3.0",
    "@angular/router": "^17.3.0",
    "@softarc/native-federation-node": "2.0.28",
    "es-module-shims": "^1.5.12",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0",
    "zone.js": "~0.14.3"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^17.3.17",
    "@angular/cli": "^17.3.5",
    "@angular/compiler-cli": "^17.3.0",
    "@types/jasmine": "~5.1.0",
    "concurrently": "^9.2.1",
    "jasmine-core": "~5.1.0",
    "karma": "~6.4.0",
    "karma-chrome-launcher": "~3.2.0",
    "karma-coverage": "~2.2.0",
    "karma-jasmine": "~5.1.0",
    "karma-jasmine-html-reporter": "~2.1.0",
    "typescript": "~5.4.2"
  }
}
